{
  "rules": {
    "personagens": {
      ".read": true,
      ".write": false,
      "$nome": {
        ".write": true,
        ".validate": "newData.exists() && newData.hasChildren() && $nome.length >= 1 && $nome.length <= 50",
        "posicao": {
          ".validate": "(!newData.child('x').exists() || newData.child('x').isNumber()) && (!newData.child('y').exists() || newData.child('y').isNumber()) && (!newData.child('z').exists() || newData.child('z').isNumber())"
        },
        "iniciativa": {
          ".validate": "!newData.exists() || newData.isNumber()"
        },
        "vida": {
          "atual": { ".validate": "!newData.exists() || newData.isNumber()" },
          "base": { ".validate": "!newData.exists() || newData.isNumber()" }
        },
        "mana": {
          "atual": { ".validate": "!newData.exists() || newData.isNumber()" },
          "base": { ".validate": "!newData.exists() || newData.isNumber()" }
        },
        "aura": {
          "atual": { ".validate": "!newData.exists() || newData.isNumber()" },
          "base": { ".validate": "!newData.exists() || newData.isNumber()" }
        },
        "chakra": {
          "atual": { ".validate": "!newData.exists() || newData.isNumber()" },
          "base": { ".validate": "!newData.exists() || newData.isNumber()" }
        },
        "corpo": {
          "atual": { ".validate": "!newData.exists() || newData.isNumber()" },
          "base": { ".validate": "!newData.exists() || newData.isNumber()" }
        }
      }
    },
    "feed_combate": {
      ".read": true,
      ".write": false,
      "$entry": {
        ".write": true,
        ".validate": "newData.hasChildren() && newData.child('tipo').exists() && newData.child('nome').exists() && newData.child('tipo').isString() && newData.child('nome').isString() && newData.child('tipo').val().length <= 50 && newData.child('nome').val().length <= 50"
      }
    },
    "jukebox": {
      ".read": true,
      ".write": true,
      ".validate": "newData.hasChildren(['playing'])",
      "playing": {
        ".validate": "newData.isBoolean()"
      },
      "videoId": {
        ".validate": "!newData.exists() || (newData.isString() && newData.val().length == 11)"
      },
      "inputUrl": {
        ".validate": "newData.isString() && newData.val().length <= 200 && (newData.val() === '' || newData.val().matches(/^https:\\/\\/(www\\.)?(youtube\\.com|youtu\\.be)\\/.+$/))"
      },
      "$unknown": {
        ".validate": false
      }
    },
    "dummies": {
      ".read": true,
      ".write": true
    },
    "$other": {
      ".read": false,
      ".write": false
    }
  }
}